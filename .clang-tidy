---

# Until https://github.com/llvm/llvm-project/issues/192713 closes and 
# clang-tidy is updated, please keep at least one clang-tidy check around so 
# clang-diagnostics-* can run and bubble up to clang-tidy.
Checks: >
  -*,
  bugprone-*,
  -bugprone-narrowing-conversions,
  -bugprone-easily-swappable-parameters,
  -bugprone-implicit-widening-of-multiplication-result,
  clang-analyzer-*,
  clang-diagnostic-*,
  misc-*,
  -misc-include-cleaner,
  modernize-*,
  -modernize-macro-to-enum,
  performance-*,
  -performance-no-int-to-ptr,
  portability-*,
  readability-*,
  -readability-identifier-length,
  -readability-isolate-declaration,
  -readability-magic-numbers,
  -readability-uppercase-literal-suffix,

# Ideally this should be ExtraArgs instead, maybe one day once this closes:
# https://github.com/llvm/llvm-project/issues/88390
ExtraArgsBefore:
  - -Wimplicit-function-declaration
  - -Wunused-variable

CheckOptions:
  - { key: readability-braces-around-statements.ShortStatementLines, value: 1 }

ExcludeHeaderFilterRegex: "src/sdk/.*"
WarningsAsErrors: "*"
FormatStyle: "file"
